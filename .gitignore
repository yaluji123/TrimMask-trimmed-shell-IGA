# The package intentionally includes the AutoCAD/ObjectARX runtime binaries
# needed to load the plug-in. Symbol files remain ignored because they are not
# required for execution and exceed ordinary repository file-size limits.
!plugin/
!plugin/AutoCAD_2025_Release_x64/
!plugin/AutoCAD_2025_Release_x64/*.dll
!plugin/AutoCAD_2025_Release_x64/*.arx
!plugin/AutoCAD_2025_Release_x64/*.dbx
